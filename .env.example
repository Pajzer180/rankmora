# Public app base URL (used for snippet generation and public links)
# Local dev: http://localhost:3000
# Production: https://app.bress.io
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public Firebase web config
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_web_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id

# Server-only Firebase Admin credentials
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace_with_your_private_key\n-----END PRIVATE KEY-----\n"

# Server-only Google Search Console OAuth config
GOOGLE_SEARCH_CONSOLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_SEARCH_CONSOLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_SEARCH_CONSOLE_REDIRECT_URI=http://localhost:3000/api/gsc/callback

# Server-only provider keys
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key

# Server-only encryption secrets
WORDPRESS_CREDENTIALS_SECRET=replace_with_a_random_32_plus_char_secret_for_wordpress_only
GSC_TOKENS_SECRET=replace_with_a_different_random_32_plus_char_secret_for_gsc_tokens

# Server-only cron auth secret
CRON_SECRET=replace_with_a_random_secret_for_cron_routes

# Server-side rate limits (per application instance)
RATE_LIMIT_CHAT_MAX=20
RATE_LIMIT_CHAT_WINDOW_MS=60000
RATE_LIMIT_GENERATE_MAX=10
RATE_LIMIT_GENERATE_WINDOW_MS=60000
RATE_LIMIT_WORDPRESS_CONNECT_MAX=10
RATE_LIMIT_WORDPRESS_CONNECT_WINDOW_MS=300000
RATE_LIMIT_WORDPRESS_TEST_MAX=10
RATE_LIMIT_WORDPRESS_TEST_WINDOW_MS=300000
RATE_LIMIT_WORDPRESS_FETCH_MAX=30
RATE_LIMIT_WORDPRESS_FETCH_WINDOW_MS=60000
RATE_LIMIT_WORDPRESS_PREVIEW_MAX=10
RATE_LIMIT_WORDPRESS_PREVIEW_WINDOW_MS=60000
RATE_LIMIT_WORDPRESS_APPLY_MAX=10
RATE_LIMIT_WORDPRESS_APPLY_WINDOW_MS=300000
RATE_LIMIT_GSC_CONNECT_MAX=10
RATE_LIMIT_GSC_CONNECT_WINDOW_MS=300000
RATE_LIMIT_GSC_CALLBACK_MAX=20
RATE_LIMIT_GSC_CALLBACK_WINDOW_MS=300000
RATE_LIMIT_GSC_SITES_MAX=30
RATE_LIMIT_GSC_SITES_WINDOW_MS=60000
RATE_LIMIT_GSC_SELECT_SITE_MAX=20
RATE_LIMIT_GSC_SELECT_SITE_WINDOW_MS=60000